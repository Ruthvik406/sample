groovy
pipeline {
    agent any

    environment {
        DOCKERHUB_CREDS = credentials('dockerhub-creds')
        DOCKER_IMAGE = 'your-dockerhub-username/node-app'
        EC2_IP = '13.233.107.237'
    }

    stages {
        stage('Checkout') {
            steps {
                git branch: 'main', url: 'https://github.com/Ruthvik406/sample.git'
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    dockerImage = docker.build "${DOCKER_IMAGE}:${BUILD_NUMBER}"
                }
            }
        }

        stage('Push to Docker Hub') {
            steps {
                script {
                    docker.withRegistry('', DOCKERHUB_CREDS) {
                        dockerImage.push()
                    }
                }
            }
        }

        stage('Deploy to EC2') {
            steps {
                sshagent(['ec2-ssh-key']) {
                    sh """
                        ssh -o StrictHostKeyChecking=no ubuntu@${3.110.27.182} "
                            docker pull ${DOCKER_IMAGE}:${BUILD_NUMBER}
                            docker stop node-app || true
                            docker rm node-app || true
                            docker run -d --name node-app -p 3000:3000 ${DOCKER_IMAGE}:${BUILD_NUMBER}
                        "
                    """
                }
            }
        }
    }

    post {
        always {
            script {
                dockerImage.cleanup()
            }
        }
    }
}
